{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "typescript",
    "unicorn",
    "oxc",
    "react",
    "vitest",
    "import",
    "jsx-a11y"
  ],
  "categories": {
    "correctness": "error",
    "suspicious": "error"
  },
  "rules": {
    "complexity": "error",
    "prefer-const": "error",
    "no-var": "error",
    "no-param-reassign": "error",
    "no-mutable-exports": "error",
    "prefer-readonly": "error",
    "@typescript-eslint/no-explicit-any": "error",
    "react/react-in-jsx-scope": "off",
    "import/no-unassigned-import": "off"
  },
  "env": {
    "builtin": true,
    "browser": true,
    "node": true
  },
  "ignorePatterns": [
    "node_modules",
    ".next",
    "dist",
    "build",
    "*.config.js",
    "*.config.ts"
  ],
  "overrides": [
    {
      "files": ["**/*.d.ts"],
      "rules": {
        "unicorn/require-module-specifiers": "off"
      }
    }
  ]
}
