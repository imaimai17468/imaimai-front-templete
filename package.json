{
  "name": "my-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "node .output/server/index.mjs",
    "lint": "oxlint src",
    "lint:fix": "oxlint --fix src",
    "format": "oxfmt --check src",
    "format:fix": "oxfmt --write src",
    "check": "oxlint src && oxfmt --check src",
    "check:fix": "oxlint --fix src && oxfmt --write src",
    "typecheck": "tsgo --noEmit",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv",
    "test": "vitest --run",
    "knip": "knip",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:pull": "drizzle-kit pull",
    "db:push:local": "bash scripts/setup-local-db.sh",
    "db:seed:local": "bun run scripts/seed-local.ts",
    "preview": "vite build && wrangler dev",
    "deploy": "vite build && wrangler deploy"
  },
  "dependencies": {
    "@hookform/resolvers": "5.1.1",
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-dropdown-menu": "2.1.15",
    "@radix-ui/react-label": "2.1.7",
    "@radix-ui/react-slot": "1.2.3",
    "@tanstack/react-router": "1.168.26",
    "@tanstack/react-start": "1.167.52",
    "better-auth": "1.6.8",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.2",
    "lefthook": "1.12.2",
    "lucide-react": "0.525.0",
    "next-themes": "0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "7.61.1",
    "sonner": "2.0.6",
    "tailwind-merge": "3.3.1",
    "zod": "4.0.10"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260430.1",
    "@tailwindcss/postcss": "4.2.4",
    "@testing-library/dom": "10.4.0",
    "@testing-library/react": "16.3.0",
    "@types/node": "25.6.0",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@typescript/native-preview": "7.0.0-dev.20260130.1",
    "@vitejs/plugin-react": "4.7.0",
    "dotenv": "17.2.1",
    "drizzle-kit": "0.31.4",
    "jsdom": "29.0.2",
    "knip": "6.5.0",
    "oxfmt": "0.46.0",
    "oxlint": "1.42.0",
    "tailwindcss": "4.2.4",
    "tw-animate-css": "1.3.6",
    "typescript": "5.8.3",
    "vite": "8.0.10",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "3.2.4",
    "wrangler": "4.84.1"
  }
}
