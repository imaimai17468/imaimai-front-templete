{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/client.tsx",
    "src/router.tsx",
    "src/app/**/{page,layout,loading,error,not-found,route}.{ts,tsx}",
    "scripts/**/*.{ts,js,sh}",
    "src/components/ui/**/*.{ts,tsx}",
    "src/lib/utils.ts"
  ],
  "project": ["src/**/*.{ts,tsx}"],
  "ignore": [
    "src/actions/**",
    "src/middleware.ts",
    "src/app/**",
    "src/components/shared/header/**",
    "src/gateways/**",
    "src/lib/auth/session.ts",
    "src/lib/drizzle/db.ts",
    "src/lib/storage/r2.ts"
  ],
  "ignoreDependencies": ["lefthook", "tailwindcss", "tw-animate-css", "@tailwindcss/postcss"]
}
